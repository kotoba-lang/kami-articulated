<?xml version="1.0" encoding="utf-8"?>
<!--
  Cartpole reference URDF for e7m-sim R1.1 PoC (ADR-2605261800).
  Geometry / inertia values match Isaac Lab `isaaclab_assets.robots.cartpole`
  (Apache-2.0 task DSL header port; cf. ADR-2605261600 N3 carve-out).

  Topology:
    world  -[slider]-  cart  -[revolute]-  pole_link

  Tuned for Cartpole-v1 baseline: pole length 0.5 m, pole mass 0.1 kg,
  cart mass 1.0 kg, slider range ±2.4 m, gravity 9.81 m/s², action = force on cart.
-->
<robot name="cartpole">

  <link name="world"/>

  <link name="cart">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.0083" iyy="0.0083" izz="0.0083" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.4 0.2 0.2"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.4 0.2 0.2"/>
      </geometry>
    </collision>
  </link>

  <joint name="slider_to_cart" type="prismatic">
    <parent link="world"/>
    <child link="cart"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-2.4" upper="2.4" effort="100.0" velocity="100.0"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>

  <link name="pole_link">
    <inertial>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.0021" iyy="0.0021" izz="0.00002" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.5" radius="0.025"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.5" radius="0.025"/>
      </geometry>
    </collision>
  </link>

  <joint name="cart_to_pole" type="revolute">
    <parent link="cart"/>
    <child link="pole_link"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14159" upper="3.14159" effort="0.0" velocity="100.0"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>

</robot>
